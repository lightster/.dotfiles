{
  "permissions": {
    "allow": [
      "Bash(npm run check:*)",
      "Bash(npm run codegen:*)",
      "Bash(grep:*)",
      "Bash(ls:*)",
      "Bash(tail:*)",
      "Bash(git check-ignore:*)",
      "Bash(git checkout:*)",
      "Bash(git pull)",
      "Bash(git push:*)",
      "Skill(commit)"
    ],
    "defaultMode": "plan"
  },
  "model": "opus",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.dotfiles/claude/hooks/validate-git-push.sh"
          },
          {
            "type": "command",
            "command": "~/.dotfiles/claude/hooks/deny-rm-root/deny-rm-root"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.dotfiles/claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "feature-dev@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": false,
    "pr-review-toolkit@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true
  },
  "sandbox": {
    "enabled": true,
    "allowUnsandboxedCommands": true,
    "filesystem": {
      "allowWrite": [
        "~/.claude",
        "~/.gnupg"
      ]
    },
    "network": {
      "allowUnixSockets": [
        "~/.gnupg/S.gpg-agent"
      ]
    }
  },
  "autoUpdatesChannel": "stable",
  "effortLevel": "high"
}
