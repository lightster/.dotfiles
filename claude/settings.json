{
  "cleanupPeriodDays": 90,
  "permissions": {
    "allow": [
      "Bash(npm run check:*)",
      "Bash(npm run codegen:*)",
      "Bash(grep:*)",
      "Bash(ls:*)",
      "Bash(tail:*)",
      "Bash(git check-ignore:*)",
      "Bash(git checkout:*)",
      "Bash(git fetch:*)",
      "Bash(git pull)",
      "Bash(git push:*)",
      "Skill(commit)",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:gitlab.atticus.com)"
    ],
    "defaultMode": "default"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.dotfiles/claude/hooks/validate-git-push.sh"
          },
          {
            "type": "command",
            "command": "~/.dotfiles/claude/hooks/deny-rm-root/deny-rm-root"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.dotfiles/claude/hooks/archive-sessions.sh"
          },
          {
            "type": "command",
            "command": "~/.dotfiles/claude/hooks/random-st-character.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.dotfiles/claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "feature-dev@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": false,
    "pr-review-toolkit@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true
  },
  "sandbox": {
    "enabled": true,
    "allowUnsandboxedCommands": false,
    "network": {
      "allowedDomains": [
        "proxy.golang.org",
        "sum.golang.org"
      ],
      "allowUnixSockets": [
        "~/.gnupg/S.gpg-agent",
        "~/.gnupg/S.gpg-agent.ssh"
      ]
    },
    "filesystem": {
      "allowWrite": [
        "~/.claude",
        "~/.gnupg",
        "~/.config/glab-cli",
        "~/Library/Caches/go-build",
        "~/go/pkg"
      ]
    },
    "enableWeakerNetworkIsolation": true,
    "excludedCommands": [
      "git push",
      "git push -u origin HEAD"
    ]
  },
  "autoUpdatesChannel": "latest",
  "remoteControlAtStartup": true,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true
}
