[user]
        name = Matt Light
        signingkey = ~/.ssh/id_ed25519.pub
[core]
        editor = vim
        excludesfile = ~/.dotfiles/git/gitignore
        attributesfile = ~/.dotfiles/git/gitattributes
        autocrlf = input
        pager = delta
[interactive]
        diffFilter = delta --color-only
[delta]
        navigate = true
        line-numbers = true
[merge]
        tool = vimdiff
[init]
        defaultBranch = main
[alias]
        unstage = reset HEAD --
        last = log -1 HEAD
        br = branch --sort=-committerdate
        st = status
        sd = diff --staged
        sh = stash
        discard = checkout --
        log-v = show --name-status
        cl = "!f() { local DEST="${HOME}/github/${1}" ; test -d "${DEST}" || gh repo clone \"${1}\" \"${DEST}\"; }; f"
        cpm = cherry-pick -m 1 --no-commit
        co = checkout
        # switch to a branch, creating it if necessary
        go = "!f() { local branch="$(git prefix-branch)$1" ; echo "$branch" ; git checkout -b \"$branch\" 2> /dev/null || git checkout \"$branch\"; }; f"
        dm = "!git branch --merged | grep -v '\\*' | xargs -n 1 git branch -d && git remote prune origin"
        p = push
        po = "!git push -u origin $(git symbolic-ref HEAD | sed -e 's#^refs/heads/##')"
        prefix-branch = "!echo \"\""
        changelog = "log --no-merges --date=short --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cd)%Creset'"
[push]
        default = simple
[pull]
        rebase = true
[commit]
        gpgsign = true
[tag]
        gpgsign = true
[color]
        branch = auto
        diff = auto
        status = auto
[url "ssh://git@github.com/"]
        insteadOf = https://github.com/

[gpg]
        format = ssh
[gpg "ssh"]
        allowedSignersFile = ~/.dotfiles/ssh/allowed_signers

[include]
        path = ~/.dotfiles/git/config.d/personal.gitconfig

# these configs are optional / added on certain systems;
# missing configs are silently ignored
[include]
        path = ~/.gitconfig-windows
[include]
        path = ~/.dotfiles/git/config.d/signing-1password.local.gitconfig

[includeIf "gitdir:/**/github/kelvineducation/"]
        path = ~/.dotfiles/git/config.d/kelvin.gitconfig
[includeIf "gitdir:/**/github/tinyprint/"]
        path = ~/.dotfiles/git/config.d/tinyprint.gitconfig
[includeIf "gitdir:/**/github/atticuslabs/"]
        path = ~/.dotfiles/git/config.d/atticus.gitconfig
[includeIf "gitdir:/**/github/atticus/"]
        path = ~/.dotfiles/git/config.d/atticus.gitconfig
[includeIf "gitdir:/**/code/atticus/"]
        path = ~/.dotfiles/git/config.d/atticus.gitconfig
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true

