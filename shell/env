export PSQL_EDITOR="vim"
export GIT_EDITOR="vim"
export HOMEBREW_CASK_OPTS="--appdir=/Applications"
export HISTCONTROL=ignorespace
export HISTTIMEFORMAT="%Y-%m-%dT%H:%M:%S "

# we change the socket location via ~/.ssh/config;
# we need to update the env var to allow `ssh-add` to work
[ "$(uname -s)" = Linux ] && export SSH_AUTH_SOCK="${XDG_RUNTIME_DIR}/ssh-agent.sock"
