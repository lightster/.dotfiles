alias cd='echo "💜 💙 💚 " ; cd'

ls --color=auto &>/dev/null
if [ $? -eq 0 ]; then
    alias ls='ls -GF --color=auto'
else
    alias ls='ls -GF'
fi
alias ll='ls -l'
alias sudo='sudo ' # allow for aliases to work when using sudo

alias b='buoy $(< ~/.dotfiles/buoy)'
alias g=git
alias c='docker compose'
alias d=docker
alias m=make

alias ~='cd ~'
alias -- -='cd -'
alias ..='cd ..'
alias ...='cd ../..'

alias dotfiles="cd ~/.dotfiles"
